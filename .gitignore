# ═══════════════════════════════════════════════════════
#  NATIQA — .gitignore
# ═══════════════════════════════════════════════════════

# ── Secrets (NEVER commit these) ────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
.pytest_cache/

# ── Node / Next.js ───────────────────────────────────────
node_modules/
.next/
out/
frontend/.next/
frontend/node_modules/

# ── Uploads / Vectors (use Railway Volume) ───────────────
uploads/
vectors/
*.pdf
*.docx
*.xlsx

# ── Logs ─────────────────────────────────────────────────
*.log
logs/

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Test artefacts ───────────────────────────────────────
htmlcov/
.coverage
frontend/tsconfig.tsbuildinfo
