# ═══════════════════════════════════════════════════════════════════════
#  NATIQA Platform — Environment Variables Reference
#  Copy to .env for local development:  cp .env.example .env
#
#  For Railway deployment: add each variable in
#  Railway Dashboard → Your Service → Variables tab
#  (Do NOT commit .env to git — it is in .gitignore)
# ═══════════════════════════════════════════════════════════════════════


# ────────────────────────────────────────────────────────────────────────
# SECTION 1 — DATABASE
# Railway Postgres plugin auto-sets DATABASE_URL.
# For local Docker: use the format below.
# ────────────────────────────────────────────────────────────────────────

# Railway injects this automatically when you add the Postgres plugin:
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Local Docker Compose only (not needed on Railway):
POSTGRES_DB=natiqa
POSTGRES_USER=natiqa_admin
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_MIN_16_CHARS


# ────────────────────────────────────────────────────────────────────────
# SECTION 2 — REDIS
# Railway Redis plugin auto-sets REDIS_URL.
# ────────────────────────────────────────────────────────────────────────

# Railway injects this automatically when you add the Redis plugin:
REDIS_URL=redis://default:password@host:6379

# Local Docker Compose only:
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD


# ────────────────────────────────────────────────────────────────────────
# SECTION 3 — SECURITY  ⚠ CRITICAL — Generate fresh values, never reuse
# Generate both with:  openssl rand -hex 32
# ────────────────────────────────────────────────────────────────────────

SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_hex_32


# ────────────────────────────────────────────────────────────────────────
# SECTION 4 — LLM PROVIDER
# Set LLM_PROVIDER=claude  for Anthropic (default, recommended)
# Set LLM_PROVIDER=ollama  for local/private deployment (no Ollama on Railway)
# ────────────────────────────────────────────────────────────────────────

LLM_PROVIDER=claude

# Required when LLM_PROVIDER=claude:
CLAUDE_API_KEY=sk-ant-api03-YOUR_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-20250514

# Required when LLM_PROVIDER=ollama (local only):
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text


# ────────────────────────────────────────────────────────────────────────
# SECTION 5 — EMAIL (OTP delivery)
# Phase 1: MOCK mode (OTP logged to console, returned in response if DEBUG=True)
# Phase 1.5: Set RESEND_API_KEY to go live — see registration.py _send_otp_email()
# Get key at: https://resend.com/api-keys
# ────────────────────────────────────────────────────────────────────────

RESEND_API_KEY=re_YOUR_RESEND_KEY_HERE
RESEND_FROM_EMAIL=verify@natiqa.ai


# ────────────────────────────────────────────────────────────────────────
# SECTION 6 — FIRST ADMIN ACCOUNT
# Created automatically on first startup by init_db()
# Change these before first deploy — especially the password
# ────────────────────────────────────────────────────────────────────────

FIRST_ADMIN_EMAIL=admin@yourcompany.com
FIRST_ADMIN_PASSWORD=CHANGE_THIS_MIN_12_CHARS_UPPER_LOWER_DIGIT_SPECIAL
FIRST_ADMIN_NAME=مدير النظام


# ────────────────────────────────────────────────────────────────────────
# SECTION 7 — APP SETTINGS
# ────────────────────────────────────────────────────────────────────────

ENVIRONMENT=production
DEBUG=False

# CORS: add your Railway domain and any custom domains
# Example: https://natiqa-production.up.railway.app,https://app.natiqa.ai
CORS_ORIGINS=https://your-railway-frontend-url.up.railway.app,https://yourdomain.com

# Frontend API URL (used by Next.js to call the backend)
# Set this to your Railway backend public URL
NEXT_PUBLIC_API_URL=https://your-railway-backend-url.up.railway.app/api


# ────────────────────────────────────────────────────────────────────────
# SECTION 8 — FILE STORAGE
# Railway has ephemeral filesystem — use Railway Volumes for uploads
# or switch to S3-compatible storage (Cloudflare R2 recommended)
# ────────────────────────────────────────────────────────────────────────

UPLOAD_DIR=/app/uploads
VECTOR_DIR=/app/vectors
MAX_FILE_SIZE_MB=50

# Future: S3-compatible storage (Cloudflare R2 / AWS S3)
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=
# S3_REGION=


# ────────────────────────────────────────────────────────────────────────
# SECTION 9 — RATE LIMITING
# ────────────────────────────────────────────────────────────────────────

RATE_LIMIT_PER_MINUTE=60
LOGIN_RATE_LIMIT_PER_MINUTE=5


# ════════════════════════════════════════════════════════════════════════
#  RAILWAY QUICK-START CHECKLIST
#  After adding variables, deploy and verify each in order:
#
#  [ ] DATABASE_URL     — Postgres plugin connected
#  [ ] REDIS_URL        — Redis plugin connected
#  [ ] SECRET_KEY       — Generated (openssl rand -hex 32)
#  [ ] ENCRYPTION_KEY   — Generated (different from SECRET_KEY)
#  [ ] CLAUDE_API_KEY   — Anthropic key active
#  [ ] FIRST_ADMIN_*    — Custom admin credentials set
#  [ ] CORS_ORIGINS     — Your Railway frontend URL added
#  [ ] DEBUG=False       — Production mode confirmed
#  [ ] /api/health      — Returns {"status":"ok"} after deploy
#  [ ] Migration SQL    — migrate_phase1.sql applied (see RAILWAY_DEPLOY.md)
# ════════════════════════════════════════════════════════════════════════
